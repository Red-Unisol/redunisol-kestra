# Server de validaciones MetaMap
VALIDACION_METAMAP_SERVER_BASE_URL=https://tu-metamap-server
VALIDACION_METAMAP_SERVER_CLIENT_ID=tu-client-id
VALIDACION_METAMAP_SERVER_CLIENT_SECRET=tu-client-secret
VALIDACION_METAMAP_SERVER_ALLOW_INVALID_CERTS=false

# Core financiero
VALIDACION_METAMAP_CORE_BASE_URL=https://celesol.dyndns.org:5050
VALIDACION_METAMAP_CORE_ALLOW_INVALID_CERTS=true

# Polling y timeouts
VALIDACION_METAMAP_POLL_INTERVAL_SECONDS=20
VALIDACION_METAMAP_REQUEST_TIMEOUT_SECONDS=15
VALIDACION_METAMAP_MAX_ITEMS=600

# Opcional: ruta alternativa al archivo de config
# VALIDACION_METAMAP_CONFIG_PATH=C:\ruta\validacion-metamap.env

# Opcional: ruta del log debug
# VALIDACION_METAMAP_DEBUG_LOG_PATH=C:\ruta\validacion-metamap-debug.log
