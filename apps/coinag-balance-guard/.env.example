COINAG_BALANCE_API_BASE=https://tu-coinag-cuentavista
COINAG_TRANSFER_API_BASE=https://tu-coinag-api-v2
COINAG_TOKEN_URL=https://tu-coinag-token
COINAG_USERNAME=tu-usuario
COINAG_PASSWORD=tu-password
COINAG_CLIENT_ID=
COINAG_CLIENT_SECRET=
COINAG_SCOPE=
COINAG_AUTH_SCHEME=Bearer
COINAG_TRANSFER_ENDPOINT=/Transferencia
COINAG_CONCEPTO=VAR
COINAG_ALLOW_INVALID_CERTS=false
COINAG_REQUEST_TIMEOUT_SECONDS=15
COINAG_HTTP_LOG_PATH=/var/lib/coinag-balance-guard/coinag_http_events.jsonl

BALANCE_GUARD_MONITORED_CBU=0000000000000000000000
BALANCE_GUARD_MONITORED_CUIT=20111111112
BALANCE_GUARD_SOURCE_CBU=0000000000000000000000
BALANCE_GUARD_SOURCE_CUIT=20222222223
BALANCE_GUARD_SOURCE_TITULAR=CUENTA FONDEADORA
BALANCE_GUARD_MINIMUM_BALANCE=30000000
BALANCE_GUARD_DESCRIPTION=Fondeo automatico por saldo minimo
BALANCE_GUARD_ID_PREFIX=FONDEO
BALANCE_GUARD_DRY_RUN=true
BALANCE_GUARD_COOLDOWN_SECONDS=900
BALANCE_GUARD_STALE_LOCK_SECONDS=900
BALANCE_GUARD_STATE_PATH=/var/lib/coinag-balance-guard/balance_guard_events.jsonl
BALANCE_GUARD_LOCK_PATH=/var/lib/coinag-balance-guard/balance_guard.lock
